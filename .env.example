# Leave unset for local dev — an in-memory MongoDB replica set is started automatically.
# Set to a real MongoDB connection string for staging/production.
# DATABASE_URI=mongodb://127.0.0.1:27017/cms

PAYLOAD_SECRET=YOUR_SECRET_HERE

# Required for the in-admin AI plugin (@ai-stack/payloadcms) to offer Claude as a model.
ANTHROPIC_API_KEY=
